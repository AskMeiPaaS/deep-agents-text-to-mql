# OpenAI Configuration
# Your OpenAI API Key (starts with sk-)
OPENAI_API_KEY="sk-proj-your-api-key-here"

# The OpenAI model the agent will use (e.g., gpt-4o, gpt-4o-mini)
OPENAI_MODEL="gpt-4o"

# MongoDB Connectivity
# Your MongoDB Atlas Connection String
# Example: mongodb+srv://<username>:<password>@your-cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://<username>:<password>@your-cluster.mongodb.net/?retryWrites=true&w=majority"

# The name of the operational database (e.g., sample_mflix)
OPERATIONAL_DB_NAME="sample_mflix"

# Logging & Telemetry Configuration
# Database name for storing agent chat history and MQL logs
LOG_DB_NAME="agent_telemetry_db"

# Collection name for logs
LOG_COLLECTION_NAME="chat_history_logs"
